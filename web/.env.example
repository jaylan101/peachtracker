# Copy to .env.local for local dev. Do NOT commit .env.local.
# Vercel will inject these automatically once the Supabase integration is
# connected (Supabase dashboard → Integrations → Vercel).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloudflare Workers AI — embeddings (BGE-small-en-v1.5) + reranker (bge-reranker-base).
# Still used for retrieval; only the final answer-generation LLM is now Gemini.
CF_ACCOUNT_ID=
CF_API_TOKEN=

# Google Gemini — generation model for Mulberry (final answer step).
# Model: gemini-2.5-flash. Free tier = 10 req/min (handled in route.ts).
# Get a key at: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
